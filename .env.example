# PurpleOps v2.0 - Environment Configuration
# =============================================

# ─────────────────────────────────────────────────────────────────────────
# LLM Provider (Phase 4 — DeepSeek primary default)
# ─────────────────────────────────────────────────────────────────────────
# PurpleOps defaults to DeepSeek ($0.49/mo) for primary LLM inference.
# Bedrock remains available as a switchable alternative for users with
# prior AWS commitments via LLM_PROVIDER=bedrock.
# Ollama is the local-dev fallback (no API key, runs on http://localhost:11434).

# LLM_PROVIDER: deepseek (default) | ollama | bedrock
LLM_PROVIDER=deepseek

# DeepSeek (https://api.deepseek.com/v1) — primary
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Ollama (http://localhost:11434) — local-dev / no API key
OLLAMA_BASE_URL=http://localhost:11434

# ─────────────────────────────────────────────────────────────────────────
# Legacy / optional: only used when LLM_PROVIDER=bedrock
# ─────────────────────────────────────────────────────────────────────────
# The vars below are legacy/optional. They are only consumed when
# LLM_PROVIDER=bedrock is set. DeepSeek is the new primary default.
# AWS_BEDROCK_* / BEDROCK_* are kept for users with prior AWS commitments.

# AWS Core
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# Amazon Bedrock
# legacy: only used when LLM_PROVIDER=bedrock
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
# legacy: only used when LLM_PROVIDER=bedrock
KNOWLEDGE_BASE_ID=your_kb_id

# Bedrock Model Tuning
# legacy: only used when LLM_PROVIDER=bedrock
BEDROCK_TEMPERATURE=0.7
# legacy: only used when LLM_PROVIDER=bedrock
BEDROCK_MAX_TOKENS=4096
# legacy: only used when LLM_PROVIDER=bedrock
BEDROCK_TOP_P=0.9

# DynamoDB Tables
DYNAMODB_TABLE_CAMPAIGNS=CampaignSessions
DYNAMODB_TABLE_AUDIT=AuditLogs

# S3
S3_BUCKET_REPORTS=purpleops-artifacts

# IAM Roles (separate roles for each agent - security best practice)
RED_AGENT_ROLE_ARN=arn:aws:iam::ACCOUNT_ID:role/sentinel-red-agent-role
BLUE_AGENT_ROLE_ARN=arn:aws:iam::ACCOUNT_ID:role/sentinel-blue-agent-role
COORD_AGENT_ROLE_ARN=arn:aws:iam::ACCOUNT_ID:role/sentinel-coordinator-role

# Coordinator / Campaign Defaults
DEFAULT_MAX_ATTACK_TURNS=5
DEFAULT_MAX_DEFENSE_TURNS=5
DEFAULT_MAX_TOTAL_TURNS=15
DEFAULT_TOKEN_BUDGET=50000

# Agent Mode: "default" (AgentExecutor) or "langgraph" (LangGraph Supervisor)
AGENT_MODE=default

# n8n Workflow Automation
N8N_WEBHOOK_URL=http://localhost:5678/webhook
N8N_API_KEY=your_n8n_api_key

# Agent Registry
AGENT_REGISTRY_TABLE=SentinelAgentRegistry
