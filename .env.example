# ============================================
# Sentinel AI v2.0 — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================

# ── AWS Configuration ────────────────────────────────────────────────────────
# Required: AWS credentials for Bedrock LLM and DynamoDB
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-here
AWS_SECRET_ACCESS_KEY=your-secret-key-here

# ── AWS Bedrock LLM ─────────────────────────────────────────────────────────
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_MAX_TOKENS=4096
BEDROCK_TEMPERATURE=0.2
BEDROCK_TOP_P=0.9

# ── DynamoDB Tables ──────────────────────────────────────────────────────────
DYNAMODB_TABLE_CAMPAIGNS=sentinel-campaigns
DYNAMODB_TABLE_AUDIT=sentinel-audit

# ── MongoDB (used by Docker Compose) ─────────────────────────────────────────
MONGO_URL=mongodb://localhost:27017
MONGO_DB=sentinel_ai

# ── Application Settings ─────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
DEBUG=false
DRY_RUN=false

# ── API Security ─────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET_KEY=change-me-to-a-random-secret-key

# ── Campaign Defaults ────────────────────────────────────────────────────────
MAX_ATTACK_TURNS=5
MAX_DEFENSE_TURNS=5
MAX_TOTAL_TURNS=15
TOKEN_BUDGET=50000

# ── WAF Configuration (optional — used by Blue Agent) ────────────────────────
WAF_ACL_NAME=
WAF_ACL_ID=
WAF_SCOPE=REGIONAL

# ── Security Hub (optional — used by Blue Agent) ─────────────────────────────
SECURITY_HUB_PRODUCT_ARN=

# ── n8n Webhook (optional — triggered at campaign milestones) ────────────────
N8N_WEBHOOK_URL=

# ── RAG / Vector Store (optional) ────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma
RAG_ENABLED=false
